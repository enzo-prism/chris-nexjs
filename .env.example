# Network overrides for local development
HOST=0.0.0.0
PORT=5000
REUSE_PORT_ENABLED=false
ALLOW_LOCAL_PORT_FALLBACK=true
DEV_FALLBACK_PORT=5050

# Uncomment and provide your database connection when running drizzle commands
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Public scheduling backend endpoint (Formspree)
# NEXT_PUBLIC_FORM_ENDPOINT=https://formspree.io/f/xojnrjna

# Public GA4 measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Server-side scheduling route endpoint
# SCHEDULE_FORM_ENDPOINT=https://formspree.io/f/xojnrjna

# Optional forwarding targets after successful inbox delivery
# SCHEDULE_CRM_WEBHOOK_URL=
# SCHEDULE_SLACK_WEBHOOK_URL=
